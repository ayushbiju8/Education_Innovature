# Core Django Settings
SECRET_KEY=django-insecure-change-this-to-a-strong-random-key-in-production
DEBUG=False
ALLOWED_HOSTS=your-app-domain.onrender.com,localhost,127.0.0.1

# Trusted Domains
CSRF_TRUSTED_ORIGINS=https://your-app-domain.onrender.com,http://localhost:3000,http://localhost:5173
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com,http://localhost:3000,http://localhost:5173

# Database configuration
# Set DATABASE_URL or configure individual database parameters below
DATABASE_URL=postgresql://user:password@host:port/dbname
DATABASE_SSL_REQUIRE=False

DB_NAME=innovature_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Razorpay API Credentials
RAZORPAY_API_KEY=rzp_test_TDKWKZnxEkdGMS
RAZORPAY_API_SECRET=S4xZZrVVRjbOlgZ6KGTbxjRs

# Security Settings (Optional)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Logging
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO
